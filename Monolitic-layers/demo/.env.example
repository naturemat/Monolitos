# Environment Configuration
# Copy this file to .env and update values as needed
# .env is gitignored - do not commit secrets

# Server
SERVER_PORT=8080

# Database (Dev - H2)
DB_URL=jdbc:h2:mem:enrollmentdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_USERNAME=sa
DB_PASSWORD=

# Database (Prod - PostgreSQL) - uncomment for prod profile
# DB_URL=jdbc:postgresql://localhost:5432/enrollmentdb
# DB_USERNAME=postgres
# DB_PASSWORD=your_password

# JPA/Hibernate
JPA_DDL_AUTO=create-drop
JPA_SHOW_SQL=true
HIBERNATE_FORMAT_SQL=true
HIBERNATE_DIALECT=org.hibernate.dialect.H2Dialect

# Spring Profiles
SPRING_PROFILES_ACTIVE=dev

# Logging
LOG_LEVEL=INFO
